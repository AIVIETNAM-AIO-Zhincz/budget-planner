# Budget Planner — biến môi trường backend (prefix BP_)
# Sao chép thành `.env` rồi chỉnh giá trị. KHÔNG commit `.env` (đã .gitignore).

# --- CSDL ---
# Dev mặc định SQLite; production dùng PostgreSQL.
BP_DATABASE_URL=sqlite:///./budget_planner.db
# BP_DATABASE_URL=postgresql://budget:budget@localhost:5432/budget_planner

# --- Bảo mật / JWT ---
# ĐỔI ở production (chuỗi ngẫu nhiên đủ dài).
BP_SECRET_KEY=dev-secret-change-me
BP_JWT_ALGORITHM=HS256
BP_ACCESS_TOKEN_EXPIRE_MINUTES=30
BP_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- CORS (JSON list các origin frontend được phép) ---
BP_CORS_ORIGINS=["http://localhost:5173", "http://127.0.0.1:5173"]

# --- Trợ lý LLM (tuỳ chọn, OpenAI-compatible) ---
# Để TRỐNG BP_LLM_API_KEY → Trợ lý chạy rule-based (không gọi mạng).
BP_LLM_API_KEY=
BP_LLM_MODEL=gpt-4o-mini
BP_LLM_BASE_URL=https://api.openai.com/v1
BP_LLM_TIMEOUT=12.0
